---
import PageLayout from '../components/PageLayout.astro';
import fs from 'fs';
import path from 'path';

// Load metagame data
const metagameDataPath = path.join(process.cwd(), 'output', 'metagame_data.json');
const metagameData = JSON.parse(fs.readFileSync(metagameDataPath, 'utf8'));
---

<PageLayout>
  <div class="card">
    <header class="page-header">
      <h1>Metagame Explorer</h1>
      <p class="subtitle">Deck archetype distribution across leagues</p>
    </header>

    <div class="controls">
      <div class="league-selection">
        <label class="league-checkbox">
          <input type="checkbox" id="select-all" checked />
          <span>All Leagues</span>
        </label>
        {metagameData.leagues.map((league: any) => (
          <label class="league-checkbox">
            <input type="checkbox" class="league-filter" data-league={league.leagueName} checked />
            <span>{league.leagueName}</span>
          </label>
        ))}
      </div>

      <div class="view-controls">
        <label>
          Min decks:
          <input type="number" id="min-decks" value="1" min="1" max="50" />
        </label>
        <label>
          <input type="checkbox" id="show-percentages" checked />
          Show percentages
        </label>
      </div>
    </div>

    <div class="summary-stats" id="summary-stats">
      <!-- Summary stats will be rendered here -->
    </div>

    <div class="metagame-chart">
      <h3>Top Decks</h3>
      <canvas id="bar-chart"></canvas>
    </div>

    <div class="data-table-section">
      <h3>Complete Metagame Breakdown</h3>
      <div class="metagame-table" id="table-container">
        <!-- Table will be rendered here -->
      </div>
    </div>
  </div>

  <!-- Embed metagame data as JSON -->
  <script id="metagame-data" type="application/json" set:html={JSON.stringify(metagameData)}></script>

  <!-- Chart.js library -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

  <script>
    // Wait for Chart.js to load
    window.addEventListener('load', function() {
      // Load metagame data from embedded JSON
      const metagameData = JSON.parse(document.getElementById('metagame-data').textContent);

      // Initialize state from URL or defaults
      const urlParams = new URLSearchParams(window.location.search);
      const leaguesParam = urlParams.get('leagues');

      let selectedLeagues;
      if (leaguesParam) {
        // Parse leagues from URL
        selectedLeagues = new Set(leaguesParam.split(',').filter(l => l));
      } else {
        // Default to all leagues
        selectedLeagues = new Set(metagameData.leagues.map(l => l.leagueName));
      }

      let minDecks = 1;
      let showPercentages = true;

    // Deck archetype normalization - group similar decks
    const archetypeAliases = {
      // Goblins variants
      'Goblins': 'Goblins',
      'RG Goblins': 'Goblins',
      'RB Goblins': 'Goblins',
      'R/g Goblins': 'Goblins',
      'Goblin Sligh': 'Goblins',

      // Dreadnought variants
      'Dreadnought': 'Dreadnought',
      'UW Dreadnought': 'Dreadnought',

      // Stiflenought variants
      'Stiflenought': 'Stiflenought',
      'UW Stiflenought': 'Stiflenought',
      'WUG Threshnought': 'Stiflenought',

      // Landstill variants
      'Landstill': 'Landstill',
      'UW Landstill': 'Landstill',
      'Tidestill': 'Landstill',

      // Replenish variants
      'Replenish': 'Replenish',
      'Replenish (PandeBurst)': 'Replenish',
      'PandeBurst': 'Replenish',

      // Oath Ponza variants
      'Oath Ponza': 'Oath Ponza',
      'GWr Oath Ponza': 'Oath Ponza',
      'GW Oath Ponza': 'Oath Ponza',
      'GW Ponza Oath': 'Oath Ponza',
      'RG Ponza Oath': 'Oath Ponza',
      'RG Oath': 'Oath Ponza',
      '4C Oath Ponza': 'Oath Ponza',
      '4c oath ponza': 'Oath Ponza',
      'GW Tusker Oath': 'Oath Ponza',
      'Spec Oath': 'Oath Ponza',
      'Oath Spec': 'Oath Ponza',

      // Terrageddon/Terra Oath variants
      'Terrageddon': 'Terrageddon',
      '4C Terrageddon': 'Terrageddon',
      'Terra Oath': 'Terrageddon',
      'GW terraoath': 'Terrageddon',
      '4C Terra Oath': 'Terrageddon',
      'Lan D Hoath': 'Terrageddon',
      'Terraclysm': 'Terrageddon',

      // Survival variants
      'Survival Opposition': 'Survival',
      'UG Survival Opposition': 'Survival',
      'Survival Squirrel Oppo': 'Survival',
      'UGR Survival Madness': 'Survival',
      'Survival Madness': 'Survival',
      'UG Tradewind Survival': 'Survival',
      'Survival Infestation': 'Survival',
      'Survival Welder': 'Survival',

      // Clerics variants
      'Clerics': 'Clerics',
      'Mono Black Clerics': 'Clerics',
      'Mono black clerics': 'Clerics',
      'Mono-B Clerics': 'Clerics',
      'Life Clerics': 'Clerics',

      // Zombies variants
      'Zombies': 'Zombies',
      'Mono-Black Zombies': 'Zombies',

      // Moneyball/Mono Black variants
      'Moneyball Black': 'Moneyball Black',
      'Moneyball black': 'Moneyball Black',
      'Moneyball': 'Moneyball Black',

      // Psychatog variants
      'Psychatog': 'Psychatog',
      'UB Psychatog': 'Psychatog',
      'Esper Tog': 'Psychatog',
      '5C Tog': 'Psychatog',
      '5c Psychatog': 'Psychatog',
      'Gro-a-Tog': 'Psychatog',

      // White Weenie variants
      'White Weenie': 'White Weenie',
      'White weenie': 'White Weenie',
      'WW': 'White Weenie',
      'White Stompy': 'White Weenie',

      // Madness variants
      'Madness': 'Madness',
      'UG Madness': 'Madness',
      'UG madness': 'Madness',
      'WG Madness': 'Madness',
      'GW Madness': 'Madness',

      // Control variants
      'UW Control': 'UW Control',
      'Mono Blue Control': 'UW Control',
      'Mono U Control': 'UW Control',
      'U Control': 'UW Control',
      'Bant Control': 'UW Control',

      // Welder variants
      'Welder': 'Welder',
      'Tinker Welder': 'Welder',
      'TinkUR Welder': 'Welder',
      'U/R Welder': 'Welder',
      'Mono R Welder': 'Welder',
      'Welder Prison': 'Welder',

      // FEB variants
      'FEB': 'FEB',
      'HFEB': 'FEB',
      'hFEB': 'FEB',

      // Ponza variants
      'RG Ponza': 'Ponza',
      'Mono Red Ponza': 'Ponza',

      // Elves variants
      'Elves': 'Elves',
      'Survival-less Elves': 'Elves',

      // Stompy variants
      'Stompy': 'Stompy',
      '10 Land Stompy': 'Stompy',

      // BW Control variants
      'BW Control': 'BW Control',
      'BW Contorl': 'BW Control',

      // Pox/Rack variants
      'Pox': 'Pox',
      'Rack': 'Pox',
      'Pit Rack': 'Pox',
      'Pox Pit Rack': 'Pox',
      'Black Rack': 'Pox',

      // Tide variants
      'Tide': 'Tide',
      'UB Tide': 'Tide',
      'UW Tide Control': 'Tide',

      // Burn variants
      'Burn': 'Burn',
      'Medvedev Burn': 'Burn',
      'Sligh': 'Burn',

      // Stasis variants
      'Stasis': 'Stasis',
      'UR Stasis': 'Stasis',
      'Stasis Oath': 'Stasis',
    };

    // Normalize deck name using aliases, or apply fuzzy matching
    function normalizeDeckName(deckName) {
      // First check exact alias match
      if (archetypeAliases[deckName]) {
        return archetypeAliases[deckName];
      }

      // Fuzzy matching for common patterns
      if (deckName.includes('Goblins')) return 'Goblins';
      if (deckName.includes('Dreadnought') && !deckName.includes('Stifle')) return 'Dreadnought';
      if (deckName.includes('Stiflenought')) return 'Stiflenought';
      if (deckName.includes('Landstill')) return 'Landstill';
      if (deckName.includes('Replenish') || deckName.includes('PandeBurst')) return 'Replenish';
      if (deckName.includes('Survival')) return 'Survival';
      if (deckName.includes('Clerics')) return 'Clerics';
      if (deckName.includes('Zombies')) return 'Zombies';

      // Return original if no match
      return deckName;
    }

    // Aggregate deck counts across selected leagues
    function getAggregatedData() {
      const deckCounts = {};
      const variantCounts = {}; // Track variants within each normalized deck
      let totalDecks = 0;

      // Sum counts across selected leagues
      for (const league of metagameData.leagues) {
        if (!selectedLeagues.has(league.leagueName)) continue;

        for (const [deck, count] of Object.entries(league.deckCounts)) {
          const normalizedDeck = normalizeDeckName(deck);
          deckCounts[normalizedDeck] = (deckCounts[normalizedDeck] || 0) + count;
          totalDecks += count;

          // Track variant counts
          if (!variantCounts[normalizedDeck]) {
            variantCounts[normalizedDeck] = {};
          }
          variantCounts[normalizedDeck][deck] = (variantCounts[normalizedDeck][deck] || 0) + count;
        }
      }

      // Convert to array and calculate percentages
      const metagame = Object.entries(deckCounts)
        .map(([deck, count]) => ({
          deck,
          count,
          percentage: totalDecks > 0 ? (count / totalDecks) * 100 : 0,
          variants: variantCounts[deck] // Include variant breakdown
        }))
        .sort((a, b) => b.count - a.count);

      return { metagame, totalDecks };
    }

    // Intentional color mapping for common archetypes
    const deckColorMap = {
      // Blue decks - various blue shades
      'Dreadnought': '#2E5EAA',         // Deep navy blue
      'Stiflenought': '#5B8BD0',        // Medium blue
      'UW Stiflenought': '#7BA3D8',     // Light blue
      'Landstill': '#4A90B8',           // Cyan blue
      'UW Landstill': '#6BA8CC',        // Sky blue
      'UB ZI': '#445B7C',               // Dark slate blue

      // Red/Burn decks - reds and oranges
      'Burn': '#E74C3C',                // Bright red
      'Sligh': '#D35400',               // Dark orange
      'Red Deck Wins': '#E67E22',       // Orange

      // Green/Aggro - greens
      'Oath Ponza': '#27AE60',          // Forest green
      'GWr Oath Ponza': '#52B788',      // Medium green
      'Stompy': '#229954',              // Dark green
      'Elves': '#82C46C',               // Light green
      'GR Aggro': '#9BB068',            // Olive green

      // Goblins - red/orange variants
      'Goblins': '#C0392B',             // Dark red
      'RG Goblins': '#A04000',          // Brown-red
      'RB Goblins': '#8B4513',          // Saddle brown

      // Black/Moneyball - dark purples and blacks
      'Moneyball Black': '#2C003E',     // Deep purple-black
      'The Rock': '#3E5641',            // Dark green-black (GB deck)
      'Pox': '#36213E',                 // Dark purple

      // Combo decks - purples and pinks
      'Replenish': '#9B59B6',           // Purple
      'Replenish (PandeBurst)': '#8E44AD', // Dark purple
      'Enchantress': '#D291BC',         // Pink-purple
      'Stasis': '#3A7CA5',              // Blue (blue deck)
      'Donate': '#B565D8',              // Light purple

      // Multi-color/Control - mixed colors
      'Domain': '#F39C12',              // Gold/yellow
      'Solution': '#16A085',            // Teal
      'Psychatog': '#5D4E6D',          // Purple-gray
      'Esper Tog': '#6C5B7B',          // Mauve

      // Graveyard/Reanimator - dark greens and grays
      'Reanimator': '#34495E',          // Dark slate
      'Survival': '#7D8471',            // Sage green
      'UG Survival Opposition': '#4A7C59', // Dark green
      'UGR Survival Madness': '#6B8E23', // Olive drab

      // Storm/Spell-based - electric colors
      'Frantic Storm': '#AA00FF',       // Electric purple
      'Predict Medallion': '#00CED1',   // Dark turquoise

      // White/Clerics - light colors
      'Mono Black Clerics': '#5D4E6D',  // Purple-gray
      'WW': '#E8E8E8',                  // Light gray

      // Artifact/Colorless - grays and silvers
      'Affinity': '#B0BEC5',            // Silver
      'Tron': '#78909C',                // Blue-gray

      // Multi-color utility decks
      'Devourer': '#9B2C2C',            // Red-blue (purple-red)
      'Terrageddon': '#7CB342',         // Light green (GW deck)
    };

    // Fallback colors for unmapped decks
    const fallbackColors = [
      '#0066cc', '#ff6b6b', '#4ecdc4', '#45b7d1', '#96ceb4',
      '#ffeaa7', '#74b9ff', '#a29bfe', '#fd79a8', '#fdcb6e',
      '#e17055', '#00b894', '#00cec9', '#6c5ce7', '#fab1a0',
      '#ff7675', '#55efc4', '#81ecec', '#dfe6e9', '#00aaff'
    ];

    // Get color for a deck, with fallback
    function getColorForDeck(deckName, fallbackIndex) {
      return deckColorMap[deckName] || fallbackColors[fallbackIndex % fallbackColors.length];
    }

    // Helper to adjust color brightness
    function adjustBrightness(hex, percent) {
      const num = parseInt(hex.replace('#', ''), 16);
      const amt = Math.round(2.55 * percent);
      const R = Math.min(255, (num >> 16) + amt);
      const G = Math.min(255, (num >> 8 & 0x00FF) + amt);
      const B = Math.min(255, (num & 0x0000FF) + amt);
      return `#${(0x1000000 + R * 0x10000 + G * 0x100 + B).toString(16).slice(1)}`;
    }

    // Chart.js instance
    let barChartInstance = null;

    // Render bar chart with Chart.js
    function renderChart() {
      const { metagame, totalDecks } = getAggregatedData();
      const canvas = document.getElementById('bar-chart');

      if (selectedLeagues.size === 0 || metagame.length === 0) {
        if (barChartInstance) {
          barChartInstance.destroy();
          barChartInstance = null;
        }
        return;
      }

      // Filter by min decks
      const filteredData = metagame.filter(entry => entry.count >= minDecks);

      if (filteredData.length === 0) {
        if (barChartInstance) {
          barChartInstance.destroy();
          barChartInstance = null;
        }
        return;
      }

      // Show top 25 decks, then "Other" for the rest
      const topDecks = filteredData.slice(0, 25);
      const remainingDecks = filteredData.slice(25);

      let dataToShow = [...topDecks];

      // Add "Other" if there are remaining decks
      if (remainingDecks.length > 0) {
        const otherCount = remainingDecks.reduce((sum, entry) => sum + entry.count, 0);
        const otherPercentage = (otherCount / totalDecks) * 100;
        dataToShow.push({
          deck: 'Other',
          count: otherCount,
          percentage: otherPercentage,
          variants: remainingDecks.reduce((acc, entry) => {
            acc[entry.deck] = entry.count;
            return acc;
          }, {})
        });
      }

      // Prepare data for Chart.js (keep descending order, don't reverse)
      const labels = dataToShow.map(entry => entry.deck);
      const data = dataToShow.map(entry => entry.count);
      const backgroundColors = dataToShow.map((entry, index) =>
        entry.deck === 'Other' ? '#95a5a6' : getColorForDeck(entry.deck, index)
      );

      // Destroy existing chart
      if (barChartInstance) {
        barChartInstance.destroy();
      }

      // Create new horizontal bar chart
      barChartInstance = new Chart(canvas, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            data: data,
            backgroundColor: backgroundColors,
            borderColor: backgroundColors.map(color => adjustBrightness(color, -10)),
            borderWidth: 1,
            borderRadius: 6,
            barThickness: 24
          }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          layout: {
            padding: {
              left: 10
            }
          },
          plugins: {
            legend: {
              display: false
            },
            tooltip: {
              backgroundColor: 'rgba(0, 0, 0, 0.8)',
              padding: 12,
              titleFont: { size: 14, weight: 'bold' },
              bodyFont: { size: 12 },
              callbacks: {
                label: function(context) {
                  const value = context.parsed.x;
                  const percentage = ((value / totalDecks) * 100).toFixed(1);
                  return `${value} decks (${percentage}%)`;
                },
                afterLabel: function(context) {
                  const deckName = context.label;
                  const deckEntry = dataToShow.find(entry => entry.deck === deckName);
                  if (!deckEntry || !deckEntry.variants) return null;

                  const variants = Object.entries(deckEntry.variants);
                  // Only show breakdown if there are multiple variants
                  if (variants.length <= 1) return null;

                  const variantLines = variants
                    .sort((a, b) => b[1] - a[1])
                    .map(([variant, count]) => `  • ${variant}: ${count}`)
                    .join('\n');

                  return '\nVariants:\n' + variantLines;
                }
              }
            }
          },
          scales: {
            x: {
              beginAtZero: true,
              grid: {
                color: 'rgba(0, 0, 0, 0.05)'
              },
              ticks: {
                font: { size: 11 }
              }
            },
            y: {
              grid: {
                display: false
              },
              ticks: {
                font: { size: 12, weight: '600' },
                color: '#212529',
                autoSkip: false,
                callback: function(value, index, ticks) {
                  const label = this.getLabelForValue(value);
                  // Truncate long labels to prevent layout warping
                  if (label.length > 20) {
                    return label.substring(0, 18) + '...';
                  }
                  return label;
                }
              }
            }
          },
          layout: {
            padding: {
              left: 0,
              right: 10
            }
          },
          animation: {
            duration: 750,
            easing: 'easeOutQuart'
          }
        }
      });
    }

    // Render table
    function renderTable() {
      const { metagame } = getAggregatedData();
      const tableContainer = document.getElementById('table-container');

      if (selectedLeagues.size === 0) {
        tableContainer.innerHTML = '';
        return;
      }

      const filteredData = metagame.filter(entry => entry.count >= minDecks);

      if (filteredData.length === 0) {
        tableContainer.innerHTML = '';
        return;
      }

      const rows = filteredData.map((entry, index) => `
        <tr>
          <td><span class="rank-number">${index + 1}</span></td>
          <td><span class="deck-name">${entry.deck}</span></td>
          <td><span class="count">${entry.count}</span></td>
          <td><span class="percentage">${entry.percentage.toFixed(1)}%</span></td>
        </tr>
      `).join('');

      tableContainer.innerHTML = `
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th>Deck Archetype</th>
              <th>Count</th>
              <th>Share</th>
            </tr>
          </thead>
          <tbody>
            ${rows}
          </tbody>
        </table>
      `;
    }

    // Render summary stats
    function renderSummary() {
      const { metagame, totalDecks } = getAggregatedData();
      const summaryContainer = document.getElementById('summary-stats');

      if (selectedLeagues.size === 0) {
        summaryContainer.innerHTML = '';
        return;
      }

      const uniqueArchetypes = metagame.length;
      const filteredData = metagame.filter(entry => entry.count >= minDecks);
      const topDeck = filteredData.length > 0 ? filteredData[0] : null;

      summaryContainer.innerHTML = `
        <div class="stat-card">
          <div class="stat-value">${totalDecks}</div>
          <div class="stat-label">Total Decks</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${uniqueArchetypes}</div>
          <div class="stat-label">Unique Archetypes</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${selectedLeagues.size}</div>
          <div class="stat-label">Leagues Selected</div>
        </div>
        ${topDeck ? `
          <div class="stat-card highlight">
            <div class="stat-value">${topDeck.deck}</div>
            <div class="stat-label">Most Played (${topDeck.percentage.toFixed(1)}%)</div>
          </div>
        ` : ''}
      `;
    }

    // Update URL with selected leagues
    function updateURL() {
      const url = new URL(window.location);
      if (selectedLeagues.size === metagameData.leagues.length) {
        // All leagues selected - remove param for cleaner URL
        url.searchParams.delete('leagues');
      } else if (selectedLeagues.size > 0) {
        // Some leagues selected - encode them
        url.searchParams.set('leagues', Array.from(selectedLeagues).join(','));
      } else {
        // No leagues selected - keep empty param
        url.searchParams.set('leagues', '');
      }
      window.history.replaceState({}, '', url);
    }

    // Render all
    function render() {
      renderSummary();
      renderChart();
      renderTable();
      updateURL();
    }

    // Event listeners
    const selectAllCheckbox = document.getElementById('select-all');
    const leagueCheckboxes = document.querySelectorAll('.league-filter');

    // Sync checkbox states with URL on load
    leagueCheckboxes.forEach(checkbox => {
      const leagueName = checkbox.dataset.league;
      checkbox.checked = selectedLeagues.has(leagueName);
    });
    selectAllCheckbox.checked = selectedLeagues.size === metagameData.leagues.length;

    // Handle individual league checkbox changes
    leagueCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const leagueName = checkbox.dataset.league;

        if (checkbox.checked) {
          selectedLeagues.add(leagueName);
        } else {
          selectedLeagues.delete(leagueName);
        }

        // Update "All" checkbox state
        const allChecked = Array.from(leagueCheckboxes).every(cb => cb.checked);
        selectAllCheckbox.checked = allChecked;

        render();
      });
    });

    // Handle "All" checkbox
    selectAllCheckbox.addEventListener('change', () => {
      const shouldSelectAll = selectAllCheckbox.checked;

      leagueCheckboxes.forEach(checkbox => {
        checkbox.checked = shouldSelectAll;
        const leagueName = checkbox.dataset.league;

        if (shouldSelectAll) {
          selectedLeagues.add(leagueName);
        } else {
          selectedLeagues.delete(leagueName);
        }
      });

      render();
    });

    document.getElementById('min-decks').addEventListener('input', (e) => {
      minDecks = parseInt(e.target.value) || 1;
      render();
    });

    document.getElementById('show-percentages').addEventListener('change', (e) => {
      showPercentages = e.target.checked;
      render();
    });

    // Initial render
    render();
    }); // End of window.load event listener
  </script>
</PageLayout>

<style is:global>
  .card {
    padding: 1.5rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 3px solid #e9ecef;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, #0066cc 0%, #0088ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 700;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #6c757d;
    font-weight: 500;
  }

  .controls {
    margin-bottom: 2rem;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    padding: 1.5rem;
    background: linear-gradient(to bottom, #ffffff, #f8f9fa);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .league-selection {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .league-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.9rem;
    user-select: none;
  }

  .league-checkbox input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: #0066cc;
  }

  .league-checkbox:hover {
    color: #0066cc;
  }

  .league-checkbox:hover input[type="checkbox"] {
    transform: scale(1.1);
    transition: transform 0.15s ease;
  }

  #select-all + span {
    font-weight: 700;
    color: #212529;
  }

  .view-controls {
    display: flex;
