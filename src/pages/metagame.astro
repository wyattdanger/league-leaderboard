---
import PageLayout from '../components/PageLayout.astro';
import LeagueHeader from '../components/LeagueHeader.astro';
import LeagueNav from '../components/LeagueNav.astro';
import { loadLeaguesConfig } from '../utils/data';
import fs from 'fs';
import path from 'path';

// Load leagues for navigation
const config = loadLeaguesConfig();
const allLeagues = config.leagues;

// Load metagame data
const metagameDataPath = path.join(process.cwd(), 'output', 'metagame_data.json');
const metagameData = JSON.parse(fs.readFileSync(metagameDataPath, 'utf8'));
---

<PageLayout>
  <LeagueHeader />
  <LeagueNav currentLeague={null} allLeagues={allLeagues} isOverall={false} isMetagame={true} />
  <div class="card">
    <div class="metagame-header">
      <h1>Metagame Explorer</h1>
    </div>

    <div class="controls">
      <div class="league-selection">
        <label class="league-checkbox">
          <input type="checkbox" id="select-all" checked />
          <span>All Leagues</span>
        </label>
        {metagameData.leagues.map((league: any) => (
          <label class="league-checkbox">
            <input type="checkbox" class="league-filter" data-league={league.leagueName} checked />
            <span>{league.leagueName}</span>
          </label>
        ))}
      </div>

      <div class="view-controls">
        <label>
          Min decks:
          <input type="number" id="min-decks" value="1" min="1" max="50" />
        </label>
        <label>
          <input type="checkbox" id="trophies-only" />
          Decks with 🏆 only
        </label>
      </div>
    </div>

    <div class="summary-stats" id="summary-stats">
      <!-- Summary stats will be rendered here -->
    </div>

    <div class="data-table-section">
      <div class="metagame-table" id="table-container">
        <!-- Table will be rendered here -->
      </div>
    </div>
  </div>

  <!-- Embed metagame data as JSON -->
  <script id="metagame-data" type="application/json" set:html={JSON.stringify(metagameData)}></script>

  <script>
    // Wait for Chart.js to load
    window.addEventListener('load', function() {
      // Load metagame data from embedded JSON
      const metagameData = JSON.parse(document.getElementById('metagame-data').textContent);

      // Initialize state from URL or defaults
      const urlParams = new URLSearchParams(window.location.search);
      const leaguesParam = urlParams.get('leagues');

      let selectedLeagues;
      if (leaguesParam) {
        // Parse leagues from URL
        selectedLeagues = new Set(leaguesParam.split(',').filter(l => l));
      } else {
        // Default to all leagues
        selectedLeagues = new Set(metagameData.leagues.map(l => l.leagueName));
      }

      let minDecks = parseInt(urlParams.get('minDecks')) || 1;
      let trophiesOnly = urlParams.get('trophiesOnly') === 'true';
      let sortColumn = urlParams.get('sort') || 'count';  // Default sort by count
      let sortDirection = urlParams.get('dir') || 'desc';

    // Deck archetype normalization - group similar decks
    const archetypeAliases = {
      // Goblins variants
      'Goblins': 'Goblins',
      'RG Goblins': 'Goblins',
      'RB Goblins': 'Goblins',
      'R/g Goblins': 'Goblins',
      'Goblin Sligh': 'Goblins',

      // Dreadnought variants (includes Stiflenought)
      'Dreadnought': 'Dreadnought',
      'UW Dreadnought': 'Dreadnought',
      'Stiflenought': 'Dreadnought',
      'UW Stiflenought': 'Dreadnought',
      'WUG Threshnought': 'Dreadnought',

      // Landstill variants
      'Landstill': 'Landstill',
      'UW Landstill': 'Landstill',
      'Tidestill': 'Landstill',

      // Replenish variants
      'Replenish': 'Replenish',
      'Replenish (PandeBurst)': 'Replenish',
      'PandeBurst': 'Replenish',

      // Oath Ponza variants
      'Oath Ponza': 'Oath Ponza',
      'GWr Oath Ponza': 'Oath Ponza',
      'GW Oath Ponza': 'Oath Ponza',
      'GW Ponza Oath': 'Oath Ponza',
      'RG Ponza Oath': 'Oath Ponza',
      'RG Oath': 'Oath Ponza',
      '4C Oath Ponza': 'Oath Ponza',
      '4c oath ponza': 'Oath Ponza',
      'GW Tusker Oath': 'Oath Ponza',
      'Spec Oath': 'Oath Ponza',
      'Oath Spec': 'Oath Ponza',

      // Terrageddon/Terra Oath variants
      'Terrageddon': 'Terrageddon',
      '4C Terrageddon': 'Terrageddon',
      'Terra Oath': 'Terrageddon',
      'GW terraoath': 'Terrageddon',
      '4C Terra Oath': 'Terrageddon',
      'Lan D Hoath': 'Terrageddon',
      'Terraclysm': 'Terrageddon',

      // Survival variants
      'Survival Opposition': 'Survival',
      'UG Survival Opposition': 'Survival',
      'Survival Squirrel Oppo': 'Survival',
      'UGR Survival Madness': 'Survival',
      'Survival Madness': 'Survival',
      'UG Tradewind Survival': 'Survival',
      'Survival Infestation': 'Survival',
      'Survival Welder': 'Survival',

      // Clerics variants
      'Clerics': 'Clerics',
      'Mono Black Clerics': 'Clerics',
      'Mono black clerics': 'Clerics',
      'Mono-B Clerics': 'Clerics',
      'Life Clerics': 'Clerics',

      // Zombies variants
      'Zombies': 'Zombies',
      'Mono-Black Zombies': 'Zombies',

      // Moneyball/Mono Black variants
      'Moneyball Black': 'Moneyball Black',
      'Moneyball black': 'Moneyball Black',
      'Moneyball': 'Moneyball Black',

      // Psychatog variants
      'Psychatog': 'Psychatog',
      'UB Psychatog': 'Psychatog',
      'Esper Tog': 'Psychatog',
      '5C Tog': 'Psychatog',
      '5c Psychatog': 'Psychatog',
      'Gro-a-Tog': 'Psychatog',

      // White Weenie variants
      'White Weenie': 'White Weenie',
      'White weenie': 'White Weenie',
      'WW': 'White Weenie',
      'White Stompy': 'White Weenie',

      // Madness variants
      'Madness': 'Madness',
      'UG Madness': 'Madness',
      'UG madness': 'Madness',
      'WG Madness': 'Madness',
      'GW Madness': 'Madness',

      // Control variants
      'UW Control': 'UW Control',
      'Mono Blue Control': 'Mono Blue Control',
      'Mono U Control': 'Mono Blue Control',
      'U Control': 'Mono Blue Control',
      'Bant Control': 'Bant Control',

      // Welder variants
      'Welder': 'Welder',
      'Tinker Welder': 'Welder',
      'TinkUR Welder': 'Welder',
      'U/R Welder': 'Welder',
      'Mono R Welder': 'Welder',
      'Welder Prison': 'Welder',

      // FEB variants
      'FEB': 'FEB',
      'HFEB': 'FEB',
      'hFEB': 'FEB',

      // Ponza variants
      'RG Ponza': 'Ponza',
      'Mono Red Ponza': 'Ponza',

      // Elves variants
      'Elves': 'Elves',
      'Survival-less Elves': 'Elves',

      // Stompy variants
      'Stompy': 'Stompy',
      '10 Land Stompy': 'Stompy',

      // BW Control variants
      'BW Control': 'BW Control',
      'BW Contorl': 'BW Control',

      // Pox/Rack variants
      'Pox': 'Pox',
      'Rack': 'Pox',
      'Pit Rack': 'Pox',
      'Pox Pit Rack': 'Pox',
      'Black Rack': 'Pox',

      // Tide variants
      'Tide': 'Tide',
      'UB Tide': 'Tide',
      'UW Tide Control': 'Tide',

      // Burn variants
      'Burn': 'Burn',
      'Medvedev Burn': 'Burn',
      'Sligh': 'Burn',

      // Stasis variants
      'Stasis': 'Stasis',
      'UR Stasis': 'Stasis',
      'Stasis Oath': 'Stasis',
    };

    // Normalize deck name using aliases, or apply fuzzy matching
    function normalizeDeckName(deckName) {
      // First check exact alias match
      if (archetypeAliases[deckName]) {
        return archetypeAliases[deckName];
      }

      // Fuzzy matching for common patterns
      if (deckName.includes('Goblins')) return 'Goblins';
      if (deckName.includes('Dreadnought') && !deckName.includes('Stifle')) return 'Dreadnought';
      if (deckName.includes('Stiflenought')) return 'Stiflenought';
      if (deckName.includes('Landstill')) return 'Landstill';
      if (deckName.includes('Replenish') || deckName.includes('PandeBurst')) return 'Replenish';
      if (deckName.includes('Survival')) return 'Survival';
      if (deckName.includes('Clerics')) return 'Clerics';
      if (deckName.includes('Zombies')) return 'Zombies';

      // Return original if no match
      return deckName;
    }

    // Aggregate deck counts, trophies, and match stats across selected leagues
    function getAggregatedData() {
      const deckCounts = {};
      const deckTrophies = {};
      const deckMatchStats = {};
      const variantCounts = {}; // Track variants within each normalized deck
      let totalDecks = 0;
      let totalTrophies = 0;

      // Sum counts, trophies, and match stats across selected leagues
      for (const league of metagameData.leagues) {
        if (!selectedLeagues.has(league.leagueName)) continue;

        for (const [deck, count] of Object.entries(league.deckCounts)) {
          const normalizedDeck = normalizeDeckName(deck);
          deckCounts[normalizedDeck] = (deckCounts[normalizedDeck] || 0) + count;
          totalDecks += count;

          // Track variant counts
          if (!variantCounts[normalizedDeck]) {
            variantCounts[normalizedDeck] = {};
          }
          variantCounts[normalizedDeck][deck] = (variantCounts[normalizedDeck][deck] || 0) + count;
        }

        // Sum trophies
        for (const [deck, trophyCount] of Object.entries(league.deckTrophies || {})) {
          const normalizedDeck = normalizeDeckName(deck);
          deckTrophies[normalizedDeck] = (deckTrophies[normalizedDeck] || 0) + trophyCount;
          totalTrophies += trophyCount;
        }

        // Sum match stats
        for (const [deck, stats] of Object.entries(league.deckMatchStats || {})) {
          const normalizedDeck = normalizeDeckName(deck);
          if (!deckMatchStats[normalizedDeck]) {
            deckMatchStats[normalizedDeck] = { wins: 0, losses: 0, draws: 0 };
          }
          deckMatchStats[normalizedDeck].wins += stats.wins;
          deckMatchStats[normalizedDeck].losses += stats.losses;
          deckMatchStats[normalizedDeck].draws += stats.draws;
        }
      }

      // Convert to array and calculate percentages
      const metagame = Object.entries(deckCounts)
        .map(([deck, count]) => {
          const stats = deckMatchStats[deck] || { wins: 0, losses: 0, draws: 0 };
          const totalMatches = stats.wins + stats.losses + stats.draws;
          const matchWinRate = totalMatches > 0
            ? ((stats.wins + 0.5 * stats.draws) / totalMatches) * 100
            : 0;

          return {
            deck,
            count,
            trophies: deckTrophies[deck] || 0,
            percentage: totalDecks > 0 ? (count / totalDecks) * 100 : 0,
            matchWinRate,
            matchStats: stats,
            variants: variantCounts[deck] // Include variant breakdown
          };
        })
        .sort((a, b) => b.count - a.count);

      return { metagame, totalDecks, totalTrophies };
    }

    // Render table
    function renderTable() {
      const { metagame } = getAggregatedData();
      const tableContainer = document.getElementById('table-container');

      if (selectedLeagues.size === 0) {
        tableContainer.innerHTML = '';
        return;
      }

      let filteredData = metagame.filter(entry => entry.count >= minDecks);

      if (trophiesOnly) {
        filteredData = filteredData.filter(entry => entry.trophies > 0);
      }

      if (filteredData.length === 0) {
        tableContainer.innerHTML = '';
        return;
      }

      // Calculate trophy rate for sorting
      filteredData = filteredData.map(entry => ({
        ...entry,
        trophyRate: entry.count > 0 ? (entry.trophies / entry.count) * 100 : 0
      }));

      // Sort data
      filteredData.sort((a, b) => {
        let aVal, bVal;

        switch(sortColumn) {
          case 'deck':
            return sortDirection === 'asc'
              ? a.deck.localeCompare(b.deck)
              : b.deck.localeCompare(a.deck);
          case 'count':
            aVal = a.count;
            bVal = b.count;
            break;
          case 'percentage':
            aVal = a.percentage;
            bVal = b.percentage;
            break;
          case 'trophies':
            aVal = a.trophies;
            bVal = b.trophies;
            break;
          case 'trophyRate':
            aVal = a.trophyRate;
            bVal = b.trophyRate;
            break;
          case 'matchWinRate':
            aVal = a.matchWinRate;
            bVal = b.matchWinRate;
            break;
          default:
            return 0;
        }

        return sortDirection === 'asc' ? aVal - bVal : bVal - aVal;
      });

      const rows = filteredData.map((entry, index) => {
        // Build tooltip text showing variant breakdown
        const variants = entry.variants || {};
        const variantEntries = Object.entries(variants)
          .sort((a, b) => b[1] - a[1]); // Sort by count descending

        let tooltipText = '';
        if (variantEntries.length > 1) {
          // Multiple variants - show breakdown
          tooltipText = variantEntries
            .map(([variant, count]) => `${variant}: ${count}`)
            .join('\n');
        } else if (variantEntries.length === 1 && variantEntries[0][0] !== entry.deck) {
          // Single variant with different name
          tooltipText = `Includes: ${variantEntries[0][0]}`;
        }

        const deckNameHtml = tooltipText
          ? `<span class="deck-name with-tooltip" data-tooltip="${tooltipText.replace(/\n/g, '|')}">${entry.deck}</span>`
          : `<span class="deck-name">${entry.deck}</span>`;

        return `
        <tr>
          <td><span class="rank-number">${index + 1}</span></td>
          <td>${deckNameHtml}</td>
          <td><span class="count">${entry.count}</span></td>
          <td><span class="percentage">${entry.percentage.toFixed(1)}%</span></td>
          <td><span class="trophy-count">${entry.trophies > 0 ? '🏆 ' + entry.trophies : '-'}</span></td>
          <td><span class="trophy-rate">${entry.trophies > 0 ? entry.trophyRate.toFixed(1) + '%' : '-'}</span></td>
          <td><span class="match-win-rate">${entry.matchWinRate.toFixed(1)}%</span></td>
        </tr>
      `;
      }).join('');

      const getSortIndicator = (column) => {
        if (sortColumn !== column) return '';
        return sortDirection === 'asc' ? ' ↑' : ' ↓';
      };

      tableContainer.innerHTML = `
        <table>
          <thead>
            <tr>
              <th>Rank</th>
              <th class="sortable" data-column="deck">Deck Archetype${getSortIndicator('deck')}</th>
              <th class="sortable" data-column="count">Count${getSortIndicator('count')}</th>
              <th class="sortable" data-column="percentage">Share${getSortIndicator('percentage')}</th>
              <th class="sortable" data-column="trophies">Trophies${getSortIndicator('trophies')}</th>
              <th class="sortable" data-column="trophyRate">Trophy Rate${getSortIndicator('trophyRate')}</th>
              <th class="sortable" data-column="matchWinRate">MWR${getSortIndicator('matchWinRate')}</th>
            </tr>
          </thead>
          <tbody>
            ${rows}
          </tbody>
        </table>
      `;

      // Add click handlers to sortable headers
      tableContainer.querySelectorAll('th.sortable').forEach(th => {
        th.addEventListener('click', () => {
          const column = th.dataset.column;
          if (sortColumn === column) {
            sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
          } else {
            sortColumn = column;
            sortDirection = 'desc';
          }
          renderTable();
        });
      });

      // Add tooltip handlers
      setupTooltips();
    }

    // Setup custom tooltips
    function setupTooltips() {
      const tooltipElements = document.querySelectorAll('.with-tooltip');
      let tooltip = document.getElementById('custom-tooltip');
      let activeElement = null;
      let scrollListener = null;

      // Create tooltip element if it doesn't exist
      if (!tooltip) {
        tooltip = document.createElement('div');
        tooltip.id = 'custom-tooltip';
        tooltip.className = 'custom-tooltip';
        document.body.appendChild(tooltip);
      }

      function positionTooltip(element) {
        const rect = element.getBoundingClientRect();
        const tooltipRect = tooltip.getBoundingClientRect();
        const viewportHeight = window.innerHeight;
        const viewportWidth = window.innerWidth;

        // Determine if tooltip should appear above or below
        const spaceBelow = viewportHeight - rect.bottom;
        const spaceAbove = rect.top;
        const tooltipHeight = tooltipRect.height || 100; // estimate if not yet rendered

        let top, left;

        // Position vertically (above or below)
        if (spaceBelow >= tooltipHeight + 16 || spaceBelow > spaceAbove) {
          // Show below
          top = rect.bottom + 8;
          tooltip.classList.remove('tooltip-above');
        } else {
          // Show above
          top = rect.top - tooltipHeight - 8;
          tooltip.classList.add('tooltip-above');
        }

        // Position horizontally (centered, but keep within viewport)
        left = rect.left + (rect.width / 2) - (tooltipRect.width / 2);

        // Ensure tooltip stays within viewport horizontally
        if (left < 8) {
          left = 8;
        } else if (left + tooltipRect.width > viewportWidth - 8) {
          left = viewportWidth - tooltipRect.width - 8;
        }

        tooltip.style.left = left + 'px';
        tooltip.style.top = top + 'px';
      }

      tooltipElements.forEach(element => {
        element.addEventListener('mouseenter', (e) => {
          const tooltipText = element.dataset.tooltip;
          if (!tooltipText) return;

          activeElement = element;

          // Replace | with line breaks for display
          const formattedText = tooltipText.split('|').join('<br>');
          tooltip.innerHTML = formattedText;
          tooltip.style.display = 'block';

          // Position tooltip
          positionTooltip(element);

          // Add scroll listener to reposition tooltip
          if (scrollListener) {
            window.removeEventListener('scroll', scrollListener, true);
          }
          scrollListener = () => {
            if (activeElement) {
              positionTooltip(activeElement);
            }
          };
          window.addEventListener('scroll', scrollListener, true);
        });

        element.addEventListener('mouseleave', () => {
          tooltip.style.display = 'none';
          activeElement = null;

          // Remove scroll listener
          if (scrollListener) {
            window.removeEventListener('scroll', scrollListener, true);
            scrollListener = null;
          }
        });
      });
    }

    // Render summary stats
    function renderSummary() {
      const { metagame, totalDecks } = getAggregatedData();
      const summaryContainer = document.getElementById('summary-stats');

      if (selectedLeagues.size === 0) {
        summaryContainer.innerHTML = '';
        return;
      }

      const uniqueArchetypes = metagame.length;
      const filteredData = metagame.filter(entry => entry.count >= minDecks);
      const topDeck = filteredData.length > 0 ? filteredData[0] : null;

      summaryContainer.innerHTML = `
        <div class="stat-card">
          <div class="stat-value">${totalDecks}</div>
          <div class="stat-label">Total Decks</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${uniqueArchetypes}</div>
          <div class="stat-label">Unique Archetypes</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">${selectedLeagues.size}</div>
          <div class="stat-label">Leagues Selected</div>
        </div>
        ${topDeck ? `
          <div class="stat-card highlight">
            <div class="stat-value">${topDeck.deck}</div>
            <div class="stat-label">Most Played (${topDeck.percentage.toFixed(1)}%)</div>
          </div>
        ` : ''}
      `;
    }

    // Update URL with all filter/sort state
    function updateURL() {
      const url = new URL(window.location);

      // Leagues
      if (selectedLeagues.size === metagameData.leagues.length) {
        url.searchParams.delete('leagues');
      } else if (selectedLeagues.size > 0) {
        url.searchParams.set('leagues', Array.from(selectedLeagues).join(','));
      } else {
        url.searchParams.set('leagues', '');
      }

      // Min decks (only if not default)
      if (minDecks !== 1) {
        url.searchParams.set('minDecks', minDecks);
      } else {
        url.searchParams.delete('minDecks');
      }

      // Trophies only
      if (trophiesOnly) {
        url.searchParams.set('trophiesOnly', 'true');
      } else {
        url.searchParams.delete('trophiesOnly');
      }

      // Sort (only if not default)
      if (sortColumn !== 'count' || sortDirection !== 'desc') {
        url.searchParams.set('sort', sortColumn);
        url.searchParams.set('dir', sortDirection);
      } else {
        url.searchParams.delete('sort');
        url.searchParams.delete('dir');
      }

      window.history.replaceState({}, '', url);
    }

    // Render all
    function render() {
      renderSummary();
      renderTable();
      updateURL();
    }

    // Event listeners
    const selectAllCheckbox = document.getElementById('select-all');
    const leagueCheckboxes = document.querySelectorAll('.league-filter');

    // Sync UI controls with URL state on load
    leagueCheckboxes.forEach(checkbox => {
      const leagueName = checkbox.dataset.league;
      checkbox.checked = selectedLeagues.has(leagueName);
    });
    selectAllCheckbox.checked = selectedLeagues.size === metagameData.leagues.length;
    document.getElementById('min-decks').value = minDecks;
    document.getElementById('trophies-only').checked = trophiesOnly;

    // Handle individual league checkbox changes
    leagueCheckboxes.forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const leagueName = checkbox.dataset.league;

        if (checkbox.checked) {
          selectedLeagues.add(leagueName);
        } else {
          selectedLeagues.delete(leagueName);
        }

        // Update "All" checkbox state
        const allChecked = Array.from(leagueCheckboxes).every(cb => cb.checked);
        selectAllCheckbox.checked = allChecked;

        render();
      });
    });

    // Handle "All" checkbox
    selectAllCheckbox.addEventListener('change', () => {
      const shouldSelectAll = selectAllCheckbox.checked;

      leagueCheckboxes.forEach(checkbox => {
        checkbox.checked = shouldSelectAll;
        const leagueName = checkbox.dataset.league;

        if (shouldSelectAll) {
          selectedLeagues.add(leagueName);
        } else {
          selectedLeagues.delete(leagueName);
        }
      });

      render();
    });

    document.getElementById('min-decks').addEventListener('input', (e) => {
      minDecks = parseInt(e.target.value) || 1;
      render();
    });

    document.getElementById('trophies-only').addEventListener('change', (e) => {
      trophiesOnly = e.target.checked;
      render();
    });

    // Initial render
    render();
    }); // End of window.load event listener
  </script>
</PageLayout>

<style is:global>
  .card {
    padding: 0;
  }

  .metagame-header {
    padding: 1.5rem 2rem;
    background: var(--gradient-primary);
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    text-align: left;
  }

  .metagame-header h1 {
    color: white;
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
  }

  .controls {
    margin: 2rem;
    margin-bottom: 2rem;
    border: 2px solid #e9ecef;
    border-radius: 12px;
    padding: 1.5rem;
    background: linear-gradient(to bottom, #ffffff, #f8f9fa);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .league-selection {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .league-checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-size: 0.9rem;
    user-select: none;
  }

  .league-checkbox input[type="checkbox"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: #0066cc;
  }

  .league-checkbox:hover {
    color: #0066cc;
  }

  .league-checkbox:hover input[type="checkbox"] {
    transform: scale(1.1);
    transition: transform 0.15s ease;
  }

  #select-all + span {
    font-weight: 700;
    color: #212529;
  }

  .view-controls {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #dee2e6;
  }

  .view-controls label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }

  .view-controls input[type="number"] {
    width: 60px;
    padding: 0.25rem;
    border: 1px solid #dee2e6;
    border-radius: 4px;
