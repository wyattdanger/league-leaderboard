---
import PageLayout from '../components/PageLayout.astro';

// Scenario 1: Without Mike Flores (#2 seed, 55 points - unable to attend)
const withoutFlores = [
  { seed: 1, name: 'swb', username: 'swbmtg', points: 60 },
  { seed: 2, name: 'Eli Mizock', username: 'minimiz', points: 48 },
  { seed: 3, name: 'Yosef Harari', username: 'itsCama', points: 45 },
  { seed: 4, name: 'Tencteri', username: 'Tencteri', points: 40 },
  { seed: 5, name: 'Taylorhol', username: 'Taylorhol', points: 39 },
  { seed: 6, name: 'Matt_W', username: 'Matt_W', points: 39 },
  { seed: 7, name: 'RichBucey', username: 'RichBucey', points: 39 },
  { seed: 8, name: 'Jeremy Siegel', username: 'remixmtg', points: 36 },
];

// Scenario 2: With Mike Flores (if he can attend)
const withFlores = [
  { seed: 1, name: 'swb', username: 'swbmtg', points: 60 },
  { seed: 2, name: 'Michael Flores', username: 'madmanpoet', points: 55 },
  { seed: 3, name: 'Eli Mizock', username: 'minimiz', points: 48 },
  { seed: 4, name: 'Yosef Harari', username: 'itsCama', points: 45 },
  { seed: 5, name: 'Tencteri', username: 'Tencteri', points: 40 },
  { seed: 6, name: 'Taylorhol', username: 'Taylorhol', points: 39 },
  { seed: 7, name: 'Matt_W', username: 'Matt_W', points: 39 },
  { seed: 8, name: 'RichBucey', username: 'RichBucey', points: 39 },
];
---

<PageLayout>
  <div class="card">
    <header class="page-header">
      <h1>Q1 2026 League Championship</h1>
      <p class="subtitle">Top 8 Playoff Bracket Scenarios</p>
    </header>

    <div class="scenarios-container">
      <!-- Scenario 1: Without Mike Flores -->
      <div class="scenario">
        <h2 class="scenario-title">Scenario 1: Without Mike Flores</h2>
        <p class="scenario-note">Michael Flores (Rank 2, 55 points) unable to attend<br/>Jeremy Siegel (Rank 9, 36 points) moves up</p>

        <div class="bracket">
          <div class="round quarterfinals">
            <div class="round-title">Quarterfinals</div>

            <div class="match">
              <div class="player seed-1">
                <span class="seed">#1</span>
                <span class="name">{withoutFlores[0].name}</span>
                <span class="points">{withoutFlores[0].points} pts</span>
              </div>
              <div class="player seed-8">
                <span class="seed">#8</span>
                <span class="name">{withoutFlores[7].name}</span>
                <span class="points">{withoutFlores[7].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-4">
                <span class="seed">#4</span>
                <span class="name">{withoutFlores[3].name}</span>
                <span class="points">{withoutFlores[3].points} pts</span>
              </div>
              <div class="player seed-5">
                <span class="seed">#5</span>
                <span class="name">{withoutFlores[4].name}</span>
                <span class="points">{withoutFlores[4].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-2">
                <span class="seed">#2</span>
                <span class="name">{withoutFlores[1].name}</span>
                <span class="points">{withoutFlores[1].points} pts</span>
              </div>
              <div class="player seed-7">
                <span class="seed">#7</span>
                <span class="name">{withoutFlores[6].name}</span>
                <span class="points">{withoutFlores[6].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-3">
                <span class="seed">#3</span>
                <span class="name">{withoutFlores[2].name}</span>
                <span class="points">{withoutFlores[2].points} pts</span>
              </div>
              <div class="player seed-6">
                <span class="seed">#6</span>
                <span class="name">{withoutFlores[5].name}</span>
                <span class="points">{withoutFlores[5].points} pts</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scenario 2: With Mike Flores -->
      <div class="scenario">
        <h2 class="scenario-title">Scenario 2: With Mike Flores</h2>
        <p class="scenario-note">Michael Flores (Rank 2, 55 points) able to attend<br/>Standard bracket seeding</p>

        <div class="bracket">
          <div class="round quarterfinals">
            <div class="round-title">Quarterfinals</div>

            <div class="match">
              <div class="player seed-1">
                <span class="seed">#1</span>
                <span class="name">{withFlores[0].name}</span>
                <span class="points">{withFlores[0].points} pts</span>
              </div>
              <div class="player seed-8">
                <span class="seed">#8</span>
                <span class="name">{withFlores[7].name}</span>
                <span class="points">{withFlores[7].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-4">
                <span class="seed">#4</span>
                <span class="name">{withFlores[3].name}</span>
                <span class="points">{withFlores[3].points} pts</span>
              </div>
              <div class="player seed-5">
                <span class="seed">#5</span>
                <span class="name">{withFlores[4].name}</span>
                <span class="points">{withFlores[4].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-2">
                <span class="seed">#2</span>
                <span class="name">{withFlores[1].name}</span>
                <span class="points">{withFlores[1].points} pts</span>
              </div>
              <div class="player seed-7">
                <span class="seed">#7</span>
                <span class="name">{withFlores[6].name}</span>
                <span class="points">{withFlores[6].points} pts</span>
              </div>
            </div>

            <div class="match">
              <div class="player seed-3">
                <span class="seed">#3</span>
                <span class="name">{withFlores[2].name}</span>
                <span class="points">{withFlores[2].points} pts</span>
              </div>
              <div class="player seed-6">
                <span class="seed">#6</span>
                <span class="name">{withFlores[5].name}</span>
                <span class="points">{withFlores[5].points} pts</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .card {
    padding: 1.5rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 1.8rem;
    margin-bottom: 0.25rem;
  }

  .subtitle {
    font-size: 1rem;
    color: #666;
  }

  .scenarios-container {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    justify-content: center;
  }

  .scenario {
    flex: 0 0 auto;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 1.5rem;
    background: #f8f9fa;
  }

  .scenario-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    text-align: center;
    color: #333;
  }

  .scenario-note {
    font-size: 0.8rem;
    color: #666;
    text-align: center;
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .bracket {
    display: flex;
    justify-content: center;
  }

  .round {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .round-title {
    font-size: 0.95rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.5rem;
    color: #333;
  }

  .match {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .player {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.5rem;
    background: white;
    border: 1px solid #dee2e6;
    border-radius: 3px;
    font-size: 0.85rem;
  }

  .seed {
    font-weight: 700;
    color: #6c757d;
    min-width: 24px;
    font-size: 0.8rem;
  }

  .name {
    flex: 1;
    font-weight: 600;
  }

  .points {
    font-size: 0.75rem;
    color: #6c757d;
  }

  @media (max-width: 968px) {
    .scenarios-container {
      grid-template-columns: 1fr;
    }
  }
</style>
